{
  "components": [
    {
      "crate_name": "axconfig",
      "manifest_path": "modules/axconfig/Cargo.toml",
      "default_targets": "axvisor-qemu-aarch64-arceos",
      "force_all": true
    },
    {
      "crate_name": "axhal",
      "manifest_path": "modules/axhal/Cargo.toml",
      "default_targets": "axvisor-qemu-aarch64-arceos",
      "force_all": true
    },
    {
      "crate_name": "axdriver",
      "manifest_path": "modules/axdriver/Cargo.toml",
      "default_targets": "axvisor-qemu-aarch64-arceos",
      "force_all": false
    }
  ],
  "non_code": {
    "dirs": [
      "doc/",
      "docs/"
    ],
    "exts": [
      ".md",
      ".txt",
      ".png",
      ".jpg",
      ".jpeg",
      ".svg",
      ".gif"
    ],
    "files": [
      "LICENSE",
      ".gitignore",
      ".gitattributes"
    ]
  }
}
